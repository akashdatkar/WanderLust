<% layout("/layouts/boilerplate") %>
<body>
<div class="row mt-3">
    <div class="col-8 offset-3">
    <h1><%= listing.title %></h1>
    </div>
    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="Loading..">
        <div class="card-body">
            <p class="card-text">
                Owned By: <i><%= listing.owner.username %></i><br>
                <%= listing.description %> <br>
                &#8377 <%= listing.price.toLocaleString("en-IN") %> <br>
                <%= listing.location %> <br>
                <%= listing.country %> <br>
            </p>
        </div>       
 </div> 
    <br>
    <% if(currentUser && currentUser._id.equals(listing.owner._id)) {%>
    <div class="btns mb-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a> 

            <form method="post" action="/listings/<%=listing._id %>?_method=DELETE">
                <button class="btn btn-dark offset-5">Delete</button>
            </form> 
    </div>
    <% } %>
    <div class="col-8 offset-3">
        <hr>
        <% if(currentUser){ %>
        <h4>Leave a Review</h4>
        <form method="post" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
            <div>
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
           
            <div>
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" role="10" class="form-control" required></textarea>
                <div class="invalid-feedback">
                    Please enter a some comments for review.
                </div>
            </div>

            <button class="btn btn-outline-dark mt-3 mb-2">Submit</button>
        </form>  
        <hr>
        <% } %>
        <p><b>All Reviews:</b></p>
    <div class="row">
        <% for(review of listing.reviews){ %>
        <div class="card col-5 mb-3 ms-2">
            <div class="card-body">
                <h5 class="card-title">Jon Doe</h5>
                <p class="card-text"><%= review.comment %></p>
                <p class="card-text"><%= review.rating %> stars</p>
            </div>
            <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark mb-2">Delete</button>
            </form>
        </div>
        <% } %>   
    </div>
    </div>
</div>
</body>
